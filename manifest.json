{
  "manifest_version": 3,
  "name": "Uncapped Roblox Friend Requests (Fixed Version)",
  "description": "Uncap your Roblox friend requests from 500 to unlimited",
  "version": "2.2.18",
  "icons": {
    "16": "src/imgs/icon-16.png",
    "32": "src/imgs/icon-32.png",
    "48": "src/imgs/icon-48.png",
    "128": "src/imgs/icon-128.png"
  },
  "permissions": ["cookies", "tabs", "scripting"],
  "host_permissions": ["*://*.roblox.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.roblox.com/*"],
      "js": ["dist/ts/contents/runtime.js"]
    }
  ],
  "background": {
    "service_worker": "dist/ts/background/background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/imgs/icon-128.png"],
      "matches": ["*://*.roblox.com/*"]
    }
  ]
}